import importlib
import atexit
import _piston

###################################
# This is a simple module wrapper #
###################################


def reload(func):
	def wrapper_reload(*args, **kwargs):
		importlib.reload(_piston)
		return func(*args, **kwargs)

	return wrapper_reload

@reload
def __getattr__(name):
	return getattr(_piston, name)

setattr(_piston.WrapCurvesDeformer, "BindMode", _piston.__WrapDeformer_BindMode)
setattr(_piston.GuideCurvesDeformer, "BindMode", _piston.__GuideDeformer_BindMode)

# Clear all module data
def clearAll(stage = None):

	if not stage:
		import hou

		stages = {}

		for node in hou.node('/stage').children():
			if isinstance(node, hou.LopNode):
				stage = node.stage()
				if stage:
					stages[stage.GetRootLayer().identifier] = stage

		for stage in stages.values():
			_piston.clearAllBSONData(stage)
	else:
		_piston.clearAllBSONData(stage)
	
	_piston.DeformerFactory.clear()


#
# Debug stuff
#

def printProfilerMessage():
	_piston.Profiler.printReport()

def clearProfiler():
	_piston.Profiler.clear()

atexit.register(printProfilerMessage)